# ═══════════════════════════════════════════════════════════════════════════
# HOST PRO — Variables d'environnement Azure (production)
# Copiez ce fichier → .env et remplissez les valeurs
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=HOST PRO
APP_ENV=production

# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── Azure Database for PostgreSQL Flexible Server ────────────────────────────
# Format : postgresql+asyncpg://USER:PASSWORD@HOST:5432/hostpro?ssl=require
# HOST  → hostpro-prod-pg.postgres.database.azure.com
DATABASE_URL=postgresql+asyncpg://hostproadmin:VOTRE_MOT_DE_PASSE@hostpro-prod-pg.postgres.database.azure.com:5432/hostpro?ssl=require

# Version synchrone pour Alembic (remplacer +asyncpg par rien)
DATABASE_URL_SYNC=postgresql://hostproadmin:VOTRE_MOT_DE_PASSE@hostpro-prod-pg.postgres.database.azure.com:5432/hostpro?sslmode=require

# ── Azure Cache for Redis ─────────────────────────────────────────────────────
# Format : rediss://:MOT_DE_PASSE@NOM.redis.cache.windows.net:6380/0
# (rediss:// = TLS — obligatoire sur Azure)
REDIS_URL=rediss://:VOTRE_CLE_REDIS@hostpro-prod-redis.redis.cache.windows.net:6380/0

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Connection string complète depuis : Portail Azure → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=hostprostprod;AccountKey=VOTRE_CLE_STORAGE;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=property-photos

# Optionnel — si vous préférez authentification par compte
AZURE_STORAGE_ACCOUNT_NAME=hostprostprod
AZURE_STORAGE_ACCOUNT_KEY=VOTRE_CLE_STORAGE

# ── Azure Container Apps ──────────────────────────────────────────────────────
# Injectés automatiquement par Azure (ne pas modifier manuellement)
# WEBSITE_HOSTNAME=hostpro-prod-web.azurecontainerapps.io
# CONTAINER_APP_HOSTNAME=hostpro-prod-api.azurecontainerapps.io

# ── Application Insights (monitoring & logs) ─────────────────────────────────
# Depuis : Portail Azure → Application Insights → Propriétés → Chaîne de connexion
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=XXXX;IngestionEndpoint=https://francecentral-1.in.applicationinsights.azure.com/

# ── CORS & Frontend ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.hostpro.fr,https://hostpro-prod-web.azurecontainerapps.io
FRONTEND_URL=https://app.hostpro.fr

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com → API Keys
RESEND_API_KEY=re_VOTRE_CLE_RESEND
EMAIL_FROM=noreply@hostpro.fr
EMAIL_FROM_NAME=HOST PRO

# ── Stripe (paiements & abonnements) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK
STRIPE_PRICE_STARTER=price_STARTER_ID
STRIPE_PRICE_PRO=price_PRO_ID
STRIPE_PRICE_ENTERPRISE=price_ENTERPRISE_ID
