# Application
APP_NAME=HOST PRO
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Database (Supabase / Neon / Railway PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/hostpro
DATABASE_URL_SYNC=postgresql://user:password@host:5432/hostpro

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 / Cloudflare R2
S3_BUCKET_NAME=hostpro-files
S3_REGION=eu-west-3
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=https://s3.eu-west-3.amazonaws.com

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@hostpro.fr
EMAIL_FROM_NAME=HOST PRO

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.hostpro.fr

# Frontend URL
FRONTEND_URL=http://localhost:3000
