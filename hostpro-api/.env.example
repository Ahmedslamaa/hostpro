# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=HOST PRO
APP_ENV=development
SECRET_KEY=hostpro-dev-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── Base de données ───────────────────────────────────────────────────────────
# Dev local : SQLite (aucune config nécessaire)
DATABASE_URL=sqlite+aiosqlite:///./hostpro.db

# Production Azure : Azure Database for PostgreSQL Flexible Server
# DATABASE_URL=postgresql+asyncpg://hostproadmin:PASSWORD@hostpro-prod-pg.postgres.database.azure.com:5432/hostpro?ssl=require
# DATABASE_URL_SYNC=postgresql://hostproadmin:PASSWORD@hostpro-prod-pg.postgres.database.azure.com:5432/hostpro?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
# Dev local
REDIS_URL=redis://localhost:6379/0

# Production Azure : Azure Cache for Redis
# REDIS_URL=rediss://:CLE_REDIS@hostpro-prod-redis.redis.cache.windows.net:6380/0

# ── Azure Blob Storage (photos propriétés) ────────────────────────────────────
# Production : récupérer depuis Portail Azure → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=property-photos

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@hostpro.fr
EMAIL_FROM_NAME=HOST PRO

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── CORS & Frontend ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
