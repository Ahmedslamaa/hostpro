{
  "expo": {
    "name": "HOST PRO",
    "slug": "hostpro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hostpro",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.hostpro.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour prendre des photos de vos propriétés",
        "NSPhotoLibraryUsageDescription": "Pour ajouter des photos à vos propriétés",
        "NSLocationWhenInUseUsageDescription": "Pour localiser vos propriétés sur la carte"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "fr.hostpro.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "VOTRE_EAS_PROJECT_ID"
      },
      "apiUrl": "https://app.hostpro.fr"
    },
    "owner": "hostpro"
  }
}
