# ════════════════════════════════════════════════════════════════════════════
# HOST PRO — Variables d'environnement
# IMPORTANT : Copier vers .env.local (développement) ou configurer dans
# Azure App Service > Configuration > Variables d'application (production)
# ⚠️  NE JAMAIS committer .env.local ou .env avec de vraies valeurs !
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Base de données (Azure PostgreSQL Flexible Server) ───────────────────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://hostpro_admin:VOTRE_MOT_DE_PASSE@hostpro-prod-pg.postgres.database.azure.com:5432/hostpro?sslmode=require

# ── Authentification JWT ─────────────────────────────────────────────────────
# Générer avec: openssl rand -hex 64
JWT_SECRET=CHANGEZ_MOI_AVEC_UN_SECRET_DE_64_CARACTERES_MINIMUM
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Azure Key Vault (production) ─────────────────────────────────────────────
AZURE_KEY_VAULT_URI=https://hostpro-prod-kv.vault.azure.net/
# En production, utiliser Managed Identity — pas besoin de credentials

# ── Azure Blob Storage (photos propriétés) ───────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=XXX;AccountKey=XXX;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=property-photos

# ── Azure Application Insights (monitoring) ──────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=XXXX;IngestionEndpoint=https://westeurope-5.in.applicationinsights.azure.com/

# ── Email transactionnel (Azure Communication Services ou SendGrid) ───────────
EMAIL_FROM=noreply@hostpro.fr
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXX
# OU Azure Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://hostpro-acs.communication.azure.com/;accesskey=XXX

# ── Prisma ───────────────────────────────────────────────────────────────────
# DATABASE_URL est utilisé directement par Prisma

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Secret pour les tokens CSRF (si activé)
CSRF_SECRET=CHANGEZ_MOI

# ── API externe (optionnel — intégrations futures) ───────────────────────────
# AIRBNB_CLIENT_ID=
# AIRBNB_CLIENT_SECRET=
# BOOKING_API_KEY=
